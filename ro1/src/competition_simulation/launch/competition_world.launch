-<?xml version="1.0"?>
<launch>

<env name="GAZEBO_MODEL_PATH" value="$(find competition_simulation)/models:/home/evenli/文档/Robote_Package/ro1/src/competition_simulation/models"/>
<!-- 1.启动Gazebo仿真器-->
<include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="world_name" value="$(find competition_simulation)/worlds/competition_world.world"/>
    <arg name="paused" value="true"/>
    <arg name="use_sim_time" value="true"/>
    <arg name="gui" value="true"/>
    <arg name="headless" value="false"/>
    <arg name="debug" value="false"/>

</include>
</launch>